{
  "t3code-server-custom-options": {
    "image": "ghcr.io/boblangley/devcontainers/base:noble",
    "features": {
      "t3code-server": {
        "port": "4123",
        "host": "127.0.0.1",
        "serviceUser": "root",
        "forwardVSCodeSshAgent": false
      }
    }
  },
  "t3code-server-caddy": {
    "image": "ghcr.io/boblangley/devcontainers/base:noble",
    "features": {
      "t3code-server": {
        "port": "4123",
        "dnsName": "t3.test-container.example.test"
      },
      "caddy": {}
    }
  }
}
