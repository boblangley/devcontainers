{
  "id": "codex-cli",
  "version": "2.0.0",
  "name": "Codex CLI",
  "documentationURL": "https://github.com/boblangley/devcontainers/tree/main/src/features/codex-cli",
  "description": "Installs the Codex CLI for the Dev Container user and ensures `codex` is on the PATH.",
  "options": {
    "version": {
      "type": "string",
      "default": "latest",
      "description": "Codex CLI version to install from npm."
    }
  },
  "dependsOn": {
    "ghcr.io/devcontainers/features/node:2": {
      "version": "24"
    }
  },
  "installsAfter": ["ghcr.io/devcontainers/features/common-utils"]
}
